-- Reset Operational Game System Functions Post Collapse
local function resetGameSystem()
    for _, obs in ipairs(activeObstacles) do
        obs:Destroy()
    end
    activeObstacles = {}
    
    currentScore = 0
    timeElapsed = 0
    birdYVelocity = 0
    Bird.Position = UDim2.new(0, 70, 0, 110)
    itemSpawnCountdown = 0.5
    gameActive = true
    NotificationLabel.Text = ""
end

-- Structural Intersection Evaluation Bounding Boxes
local function isColliding(element1, element2)
    local absPos1, absSize1 = element1.AbsolutePosition, element1.AbsoluteSize
    local absPos2, absSize2 = element2.AbsolutePosition, element2.AbsoluteSize
    
    return absPos1.X < absPos2.X + absSize2.X - 4 and
           absPos1.X + absSize1.X - 4 > absPos2.X and
           absPos1.Y < absPos2.Y + absSize2.Y - 4 and
           absPos1.Y + absSize1.Y - 4 > absPos2.Y
end

-- Primary Run-Loop Matrix Connect Update Channel
local connection
connection = RunService.Heartbeat:Connect(function(deltaTime)
    if not ScreenGui or not ScreenGui.Parent then
        connection:Disconnect()
        return
    end
    
    -- Animate the Outline Border Gradient Cycle (Yellow Neon Stream)
    BorderGradient.Rotation = (BorderGradient.Rotation + (deltaTime * 120)) % 360
    
    if not gameActive then return end
    
    timeElapsed = timeElapsed + deltaTime
    currentScore = math.floor(timeElapsed * 12)
    MetricsLabel.Text = string.format("Score: %d", currentScore)
    
    -- Slow Parallax Background Cloud Translation Scroll
    for index = #activeClouds, 1, -1 do
        local cloud = activeClouds[index]
        if cloud and cloud.Parent then
            cloud.Position = cloud.Position - UDim2.new(0, (constantSpeed * 12) * deltaTime, 0, 0)
            
            if cloud.AbsolutePosition.X < GameArea.AbsolutePosition.X - 70 then
                cloud:Destroy()
                table.remove(activeClouds, index)
                generateCloudElement(false)
            end
        end
    end
    
    -- Continuous Constant Flappy Gravity Calculations Update
    birdYVelocity = math.min(birdYVelocity + (gravityAcceleration * deltaTime), maxFallSpeed)
    local currentYOffset = Bird.Position.Y.Offset + (birdYVelocity * deltaTime)
    
    -- Boundary Collision Checks (Ceiling & Floor)
    local maxPlayableHeight = GameArea.AbsoluteSize.Y
    if currentYOffset <= 0 or (maxPlayableHeight > 0 and currentYOffset >= maxPlayableHeight - 25) then
        gameActive = false
        NotificationLabel.Text = "💥 CRASHED! Tap sky to restart..."
        task.wait(0.6)
        
        local clickToRestartConnection
        clickToRestartConnection = MobileClickZone.MouseButton1Click:Connect(function()
            clickToRestartConnection:Disconnect()
            resetGameSystem()
        end)
        return
    end
    Bird.Position = UDim2.new(0, 70, 0, currentYOffset)
    
    -- Procedural Fixed-Interval Pipe Generation Channel
    itemSpawnCountdown = itemSpawnCountdown - deltaTime
    if itemSpawnCountdown <= 0 then
        local canvasHeight = GameArea.AbsoluteSize.Y
        if canvasHeight == 0 then canvasHeight = 256 end
        
        local gapHeight = 84 
        local minCenter = 45 + (gapHeight / 2)
        local maxCenter = canvasHeight - 45 - (gapHeight / 2)
        local gapCenter = math.random(minCenter, maxCenter)
        
        -- Top Structural Pipe Setup
        local topPipe = Instance.new("Frame")
        topPipe.Name = "TopPipe"
        topPipe.BackgroundColor3 = Color3.fromRGB(95, 210, 95) 
        topPipe.BorderSizePixel = 0
        topPipe.Size = UDim2.new(0, 38, 0, gapCenter - (gapHeight / 2))
        topPipe.Position = UDim2.new(1, 0, 0, 0)
        topPipe.ZIndex = 2
        topPipe.Parent = GameArea
        
        local topStroke = Instance.new("UIStroke")
        topStroke.Color = Color3.fromRGB(50, 120, 50)
        topStroke.Thickness = 2
        topStroke.Parent = topPipe
        
        -- Bottom Structural Pipe Setup
        local bottomPipeTopY = gapCenter + (gapHeight / 2)
        local bottomPipe = Instance.new("Frame")
        bottomPipe.Name = "BottomPipe"
        bottomPipe.BackgroundColor3 = Color3.fromRGB(95, 210, 95)
        bottomPipe.BorderSizePixel = 0
        bottomPipe.Size = UDim2.new(0, 38, 0, canvasHeight - bottomPipeTopY)
        bottomPipe.Position = UDim2.new(1, 0, 0, bottomPipeTopY)
        bottomPipe.ZIndex = 2
        bottomPipe.Parent = GameArea
        
        local bottomStroke = Instance.new("UIStroke")
        bottomStroke.Color = Color3.fromRGB(50, 120, 50)
        bottomStroke.Thickness = 2
        bottomStroke.Parent = bottomPipe
        
        table.insert(activeObstacles, topPipe)
        table.insert(activeObstacles, bottomPipe)
        
        itemSpawnCountdown = 2.1
    end
    
    -- Translate Pipe Barriers Right-to-Left and Verify Collisions
    for index = #activeObstacles, 1, -1 do
        local currentObstacle = activeObstacles[index]
        if currentObstacle and currentObstacle.Parent then
            local translationPixels = (constantSpeed * 45) + 160
            currentObstacle.Position = currentObstacle.Position - UDim2.new(0, translationPixels * deltaTime, 0, 0)
            
            if isColliding(Bird, currentObstacle) then
                gameActive = false
                NotificationLabel.Text = "💥 WRECKED! Tap sky to restart..."
                task.wait(0.6)
                
                local clickToRestartConnection
                clickToRestartConnection = MobileClickZone.MouseButton1Click:Connect(function()
                    clickToRestartConnection:Disconnect()
                    resetGameSystem()
                end)
                return
            end
            
            if currentObstacle.AbsolutePosition.X < GameArea.AbsolutePosition.X - 50 then
                currentObstacle:Destroy()
                table.remove(activeObstacles, index)
            end
        end
    end
end)
