-- Core State Variables Engine (Balanced flat-speed runtime loop)
local gameActive = true
local constantSpeed = 3.8 
local currentScore = 0
local timeElapsed = 0

-- Engine Physics Constant Adjustments
local birdYVelocity = 0
local gravityAcceleration = 950
local flapLiftForce = -290
local maxFallSpeed = 420

local activeObstacles = {}
local activeClouds = {}
local itemSpawnCountdown = 0.5

-- Background Cloud Generator Setup
local function generateCloudElement(isInitial, customX)
    local cloud = Instance.new("TextLabel")
    cloud.Name = "Cloud"
    cloud.BackgroundTransparency = 1
    cloud.Text = "☁️"
    cloud.TextSize = math.random(35, 55)
    cloud.TextTransparency = 0.35
    cloud.Size = UDim2.new(0, 60, 0, 40)
    
    local startX = isInitial and customX or 1.1
    cloud.Position = UDim2.new(startX, 0, 0, math.random(15, 120))
    cloud.ZIndex = 1
    cloud.Parent = GameArea
    table.insert(activeClouds, cloud)
end

-- Pre-populate the sky with clouds
for i = 1, 4 do
    generateCloudElement(true, (i - 1) * 0.28 + math.random(0, 10)/100)
end

-- Trigger Flap Lift Upwards
local function triggerBirdFlap()
    if gameActive then
        birdYVelocity = flapLiftForce
    end
end

-- Map Mechanical Control Triggers
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.Space then
        triggerBirdFlap()
    end
end)

