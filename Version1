local registryTabs = {}
local currentActiveTab = ""

local function initDisplayTabLayer(name, order)
    local page = Instance.new("CanvasGroup")
    page.Name = name.."Page"
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.GroupTransparency = (order == 1) and 0 or 1
    page.Visible = (order == 1)
    page.Parent = PagesContainer
    
    if order == 1 then currentActiveTab = name end
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 30)
    btn.BackgroundColor3 = THEME.CardBG
    btn.BackgroundTransparency = (order == 1) and 0.2 or 1
    btn.Text = "   " .. name
    btn.TextColor3 = (order == 1) and THEME.TextMain or THEME.TextMuted
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 11
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.BorderSizePixel = 0
    btn.LayoutOrder = order
    btn.Parent = TabButtonGroupContainer
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 12)
    
    local Stroke = Instance.new("UIStroke")
    Stroke.Thickness = 1
    Stroke.Color = THEME.AccentMain
    Stroke.Transparency = (order == 1) and 0.6 or 1
    Stroke.Parent = btn
    
    btn.MouseEnter:Connect(function()
        if currentActiveTab ~= name then
            TweenService:Create(btn, TWEEN_FAST, {TextColor3 = THEME.TextMain, BackgroundTransparency = 0.8}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if currentActiveTab ~= name then
            TweenService:Create(btn, TWEEN_FAST, {TextColor3 = THEME.TextMuted, BackgroundTransparency = 1}):Play()
        end
    end)
    
    registryTabs[name] = {Page = page, Button = btn, Stroke = Stroke}
    return page
end

local function routeToPage(targetName)
    if currentActiveTab == targetName then return end
    local legacyData = registryTabs[currentActiveTab]
    local incomingData = registryTabs[targetName]
    currentActiveTab = targetName
    
    if legacyData then
        TweenService:Create(legacyData.Stroke, TWEEN_FAST, {Transparency = 1}):Play()
        TweenService:Create(legacyData.Button, TWEEN_FAST, {BackgroundTransparency = 1, TextColor3 = THEME.TextMuted}):Play()
        local fadeOut = TweenService:Create(legacyData.Page, TWEEN_FAST, {GroupTransparency = 1})
        fadeOut:Play()
        fadeOut.Completed:Connect(function() if currentActiveTab ~= legacyData.Page.Name:gsub("Page", "") then legacyData.Page.Visible = false end end)
    end
    if incomingData then
        incomingData.Page.Visible = true
        TweenService:Create(incomingData.Stroke, TWEEN_FAST, {Transparency = 0.6}):Play()
        TweenService:Create(incomingData.Button, TWEEN_FAST, {BackgroundTransparency = 0.2, TextColor3 = THEME.TextMain}):Play()
        incomingData.Page.GroupTransparency = 1
        TweenService:Create(incomingData.Page, TWEEN_NORMAL, {GroupTransparency = 0}):Play()
    end
end

