-- 🚀 DETAILED BOOTLOADER SEQUENCE CONTROL PIPELINE
--------------------------------------------------------------------------------
task.spawn(function()
    local targetLifespan = math.random(3, 14)
    local count = 0
    
    while count < targetLifespan do
        local increment = task.wait(0.03)
        count = math.min(count + increment, targetLifespan)
        LoadingBarFill.Size = UDim2.new(count / targetLifespan, 0, 1, 0)
    end
    
    task.wait(0.15)
    
    TweenService:Create(LoaderGroup, TWEEN_FAST, {GroupTransparency = 1}):Play()
    task.wait(0.12)
    
    local windowMorph = TweenService:Create(MainFrame, TWEEN_MORPH, {
        Size = FinalSize,
        Position = UDim2.new(0.5, -FinalSize.X.Offset/2, 0.5, -FinalSize.Y.Offset/2)
    })
    windowMorph:Play()
    
    MainUIGroup.Visible = true
    windowMorph.Completed:Connect(function()
        TweenService:Create(MainUIGroup, TWEEN_NORMAL, {GroupTransparency = 0}):Play()
        LoaderGroup:Destroy()
    end)
end)

