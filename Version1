local function buildFunctionalActionButton(parent, labelText, size, position, actionCallback)
    local containerFrame = Instance.new("Frame")
    containerFrame.Size = size
    containerFrame.Position = position
    containerFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    containerFrame.BorderSizePixel = 0
    containerFrame.Parent = parent
    
    Instance.new("UICorner", containerFrame).CornerRadius = UDim.new(0, 12)
    
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new(THEME.AccentMain, THEME.AccentDark)
    grad.Rotation = 45
    grad.Parent = containerFrame
    
    local sStroke = Instance.new("UIStroke")
    sStroke.Thickness = 1
    sStroke.Color = THEME.TextMain
    sStroke.Transparency = 0.8
    sStroke.Parent = containerFrame
    
    local visibleLabel = Instance.new("TextLabel")
    visibleLabel.Size = UDim2.new(1, 0, 1, 0)
    visibleLabel.BackgroundTransparency = 1
    visibleLabel.Text = labelText
    visibleLabel.TextColor3 = THEME.TextMain
    visibleLabel.Font = Enum.Font.GothamBold
    visibleLabel.TextSize = 11
    visibleLabel.ZIndex = 2
    visibleLabel.Parent = containerFrame
    
    local interactiveBtn = Instance.new("TextButton")
    interactiveBtn.Size = UDim2.new(1, 0, 1, 0)
    interactiveBtn.BackgroundTransparency = 1
    interactiveBtn.Text = ""
    interactiveBtn.ZIndex = 3
    interactiveBtn.Parent = containerFrame
    
    interactiveBtn.MouseEnter:Connect(function() TweenService:Create(sStroke, TWEEN_FAST, {Transparency = 0.4}):Play() end)
    interactiveBtn.MouseLeave:Connect(function() TweenService:Create(sStroke, TWEEN_FAST, {Transparency = 0.8}):Play() end)
    
    interactiveBtn.Activated:Connect(function()
        local clickEffect = TweenService:Create(containerFrame, TWEEN_FAST, {Size = UDim2.new(size.X.Scale, size.X.Offset - 2, size.Y.Scale, size.Y.Offset - 2)})
        clickEffect:Play()
        clickEffect.Completed:Connect(function() TweenService:Create(containerFrame, TWEEN_FAST, {Size = size}):Play() end)
        
        if type(actionCallback) == "string" then
            task.spawn(function()
                local success, log = pcall(function() loadstring(game:HttpGet(actionCallback))() end)
                if not success then warn("[Joy Hub Dynamic Load Fault]: " .. tostring(log)) end
            end)
        elseif type(actionCallback) == "function" then
            task.spawn(actionCallback)
        end
    end)
    
    return containerFrame
end

