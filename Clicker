-- MANUAL SCALE MULTIPLIER HANDLERS
-------------------------------------------------------------------------------
local function modifyLayoutScale(step)
    local viewport = workspace.CurrentCamera.ViewportSize
    -- Establish exact fullscreen capability boundaries safely
    local maxClampLimit = math.min(viewport.X / 660, viewport.Y / 420)
    local minClampLimit = 0.4
    
    local endScaleTarget = math.clamp(uiScale.Scale + step, minClampLimit, maxClampLimit)
    
    TweenService:Create(uiScale, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Scale = endScaleTarget
    }):Play()
end

