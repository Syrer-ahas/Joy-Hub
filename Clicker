local function createFloatingText(amount, exactPosition)
    local label = Instance.new("TextLabel")
    -- Factor UI scale adjustments into coordinate calculations to map accurately on click
    local unscaledX = (exactPosition.X - mainFrame.AbsolutePosition.X) / uiScale.Scale + mainFrame.Size.X.Offset/2
    local unscaledY = (exactPosition.Y - mainFrame.AbsolutePosition.Y) / uiScale.Scale + mainFrame.Size.Y.Offset/2
    
    label.Size = UDim2.new(0, 100, 0, 30)
    label.Position = UDim2.new(0, exactPosition.X - 50, 0, exactPosition.Y - 45)
    label.BackgroundTransparency = 1 label.Text = "+" .. formatNumber(amount)
    label.TextColor3 = Color3.fromRGB(255, 210, 80) label.Font = Enum.Font.GothamBlack label.TextSize = 18
    label.ZIndex = 10 label.Parent = screenGui

    TweenService:Create(label, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = label.Position + UDim2.new(0, math.random(-20, 20), 0, -75), TextTransparency = 1
    }):Play()
    task.delay(0.8, function() label:Destroy() end)
end

_G.MasterUpdateCall = function()
    countLabel.Text = formatNumber(PlayerData.Clicks) .. " Cookies"
    cpsLabel.Text = "per second: " .. formatNumber(getCPS())
    rebDisplay.Text = "Global Factor Boost: x" .. formatNumber(math.max(1, PlayerData.Rebirths * 3))

    for _, item in pairs(UI_Elements) do
        if item.Config then
            local cfg = item.Config
            if PlayerData.Rebirths >= cfg.RebReq then
                local cost = getNodeCost(cfg)
                item.Title.Text = cfg.Title .. " [" .. PlayerData[cfg.Key] .. "]"
                item.Desc.Text = cfg.Desc
                item.Button.Text = formatNumber(cost)
                item.Button.BackgroundColor3 = (PlayerData.Clicks >= cost) and Color3.fromRGB(0, 150, 75) or Color3.fromRGB(38, 32, 28)
            else
                item.Title.Text = "🔒 LOCKED NODE"
                item.Desc.Text = "Requires milestone Rebirth validation point " .. cfg.RebReq .. " to decipher calculations."
                item.Button.Text = "Rebirth " .. cfg.RebReq
                item.Button.BackgroundColor3 = Color3.fromRGB(70, 30, 30)
            end
        end
    end

    local rCost = getRebirthCost()
    local rbUnit = UI_Elements["RebirthNode"]
    rbUnit.Title.Text = "Galactic Rebirth (Stage " .. PlayerData.Rebirths .. ")"
    rbUnit.Desc.Text = "Resets base nodes logs in exchange for permanent global 3x generation multi-layers."
    rbUnit.Button.Text = formatNumber(rCost)
    rbUnit.Button.BackgroundColor3 = (PlayerData.Clicks >= rCost) and Color3.fromRGB(130, 50, 180) or Color3.fromRGB(45, 30, 45)
end

