-- MATH MODULATION CALCULATIONS
-------------------------------------------------------------------------------
local function getNodeCost(cfg) return math.floor(cfg.BaseCost * math.pow(cfg.Mult, PlayerData[cfg.Key])) end
local function getRebirthCost() return math.floor(1000000 * math.pow(6, PlayerData.Rebirths)) end

local function getClickValue()
    local amt = PlayerData.ClickLevel
    for _, c in ipairs(UpgradeConfig) do
        if c.Type == "Click" and c.Key ~= "ClickLevel" then amt = amt + (PlayerData[c.Key] * c.Val) end
    end
    amt = amt * (1 + (PlayerData.SugarFrenzy * 0.5))
    amt = amt * (1 + (PlayerData.NeuroLink * 1.0))
    return amt * math.max(1, PlayerData.Rebirths * 3)
end

local function getCPS()
    local total = 0
    for _, cfg in ipairs(UpgradeConfig) do
        if cfg.Type == "CPS" then total = total + (PlayerData[cfg.Key] * cfg.Val) end
    end
    return total * math.max(1, PlayerData.Rebirths * 3)
end

local function formatNumber(num)
    if num >= 1e36 then return string.format("%.2fDd", num / 1e36)
    elseif num >= 1e33 then return string.format("%.2fUd", num / 1e33)
    elseif num >= 1e30 then return string.format("%.2fDc", num / 1e30)
    elseif num >= 1e27 then return string.format("%.2fNo", num / 1e27)
    elseif num >= 1e24 then return string.format("%.2fOc", num / 1e24)
    elseif num >= 1e21 then return string.format("%.2fSp", num / 1e21)
    elseif num >= 1e18 then return string.format("%.2fSx", num / 1e18)
    elseif num >= 1e15 then return string.format("%.2fQi", num / 1e15)
    elseif num >= 1e12 then return string.format("%.2fQa", num / 1e12)
    elseif num >= 1e9 then return string.format("%.2fT", num / 1e9)
    elseif num >= 1e6 then return string.format("%.2fM", num / 1e6)
    elseif num >= 1e3 then return string.format("%.1fK", num / 1e3)
    else return tostring(math.floor(num)) end
end

