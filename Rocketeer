local function FireWeaponArray()
	if os.clock() - LastShotTime < GameState.FireRate then return end
	LastShotTime = os.clock()
	
	local shotCount = (math.random(100) <= GameState.DoubleShotChance) and 4 or 2
	local stepOffsets = (shotCount == 4) and {-0.04, -0.015, 0.015, 0.04} or {-0.02, 0.02}
	
	for _, offset in ipairs(stepOffsets) do
		local bullet = Instance.new("Frame")
		bullet.Size = UDim2.new(0.03, 0, 0.045, 0)
		bullet.BackgroundColor3 = Color3.fromRGB(255, 235, 15)
		bullet.Rotation = 45
		bullet.BorderSizePixel = 0
		bullet.ZIndex = 5
		bullet.Position = UDim2.new(Jet.Position.X.Scale + offset, 0, Jet.Position.Y.Scale - 0.05, 0)
		bullet.AnchorPoint = Vector2.new(0.5, 0.5)
		bullet.Parent = Canvas
		
		local ratio = Instance.new("UIAspectRatioConstraint")
		ratio.AspectRatio = 0.4
		ratio.Parent = bullet
		
		table.insert(Bullets, {
			Frame = bullet,
			Life = GameState.PierceCount,
			IsCrit = (math.random(100) <= GameState.CritChance)
		})
	end
end

local function BuildVessel(xScale, yScale, displayTitle, hpValue, color, isBoss, isTitan, isBehemoth)
	local enemy = Instance.new("Frame")
	
	if isBoss then
		enemy.Size = UDim2.new(0.36, 0, 0.1, 0)
	elseif isBehemoth then
		enemy.Size = UDim2.new(0.21, 0, 0.095, 0) 
	elseif isTitan then
		enemy.Size = UDim2.new(0.17, 0, 0.085, 0)
	else
		enemy.Size = UDim2.new(0.13, 0, 0.075, 0)
	end
	
	enemy.Position = UDim2.new(xScale, 0, yScale, 0)
	enemy.AnchorPoint = Vector2.new(0.5, 0.5)
	enemy.BackgroundColor3 = color
	enemy.ZIndex = 4
	enemy.Parent = Canvas
	Instance.new("UICorner").Parent = enemy
	
	local stroke = Instance.new("UIStroke")
	stroke.Thickness = (isBoss or isBehemoth) and 2.5 or 1.5
	stroke.Color = Color3.fromRGB(255, 255, 255)
	stroke.Parent = enemy
	
	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, 0, 0.9, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = displayTitle .. " [" .. hpValue .. "]"
	lbl.TextColor3 = Color3.fromRGB(10, 10, 10)
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = isBoss and 9 or 7
	lbl.ZIndex = 5
	lbl.Parent = enemy
	
	return enemy, lbl
end

local function StartNextWave()
	if GameState.Spawning or not GameState.Active then return end
	GameState.Spawning = true
	
	GameState.Wave = GameState.Wave + 1
	GameState.IsBossWave = (GameState.Wave % 5 == 0)
	
	-- LINEAR SCALING BUFF: Adds exactly +0.95x threat modifier every 10 waves
	local dynamicScaling = 1 + (0.95 * math.floor((GameState.Wave - 1) / 10))
	local isEvolutionMilestone = (GameState.Wave > 1 and (GameState.Wave - 1) % 10 == 0)
	
	if GameState.Wave > 1 then
		GameState.Health = math.min(GameState.MaxHealth, GameState.Health + GameState.ShieldRegen)
	end
	
	local notification = Instance.new("TextLabel")
	notification.Size = UDim2.new(0.9, 0, 0.15, 0)
	notification.Position = UDim2.new(0.05, 0, 0.35, 0)
	notification.BackgroundTransparency = 1
	notification.Font = Enum.Font.GothamBold
	notification.TextSize = 12
	notification.ZIndex = 7
	notification.Parent = Canvas
	
	-- Dynamic System Notifications
	if GameState.IsBossWave then
		notification.Text = "🚨 OVERLORD CONTACT IDENTIFIED 🚨"
		notification.TextColor3 = Color3.fromRGB(255, 20, 70)
	elseif isEvolutionMilestone then
		notification.Text = string.format("⚡ THREAT SPIKE: ENEMIES MUTATED +0.95x (TIER %d) ⚡", math.floor((GameState.Wave - 1) / 10))
		notification.TextColor3 = Color3.fromRGB(255, 130, 0)
	else
		notification.Text = "WARPING DESTINATION // WAVE " .. GameState.Wave
		notification.TextColor3 = Color3.fromRGB(255, 255, 255)
	end
	
	local tween = TweenService:Create(notification, TweenInfo.new(1.4), {TextTransparency = 1})
	tween:Play()
	task.delay(1.4, function() notification:Destroy() end)
	
	task.spawn(function()
		task.wait(1.0)
		
		local dbIdx = math.clamp(GameState.Wave, 1, 50)
		local dataStructure = EnemyDatabase[dbIdx]
		
		if GameState.IsBossWave then
			local bossHp = math.floor(dataStructure.BaseHP * 4 * dynamicScaling)
			local bossTitle = "BOSS: " .. dataStructure.Name
			local frame, lbl = BuildVessel(0.5, -0.1, bossTitle, bossHp, dataStructure.Color, true, false, false)
			table.insert(Enemies, {
				Frame = frame, 
				Label = lbl, 
				HP = bossHp, 
				MaxHP = bossHp, 
				IsBoss = true, 
				DirectionX = 1, 
				SpeedMod = 0.45 * dynamicScaling, 
				IsRainbow = false, 
				Data = dataStructure, 
				DisplayTitle = bossTitle
			})
		else
			local spawnsCount = math.min(6, 2 + math.floor(GameState.Wave * 0.4))
			for i = 1, spawnsCount do
				local roll = math.random(100)
				local hpMultiplier = 1
				local speedMultiplier = 1
				local mutationTag = ""
				local isRainbow = false
				local isTitan = false
				local isBehemoth = false
				
				if roll <= 5 then
					isRainbow = true
					mutationTag = "🌈 "
				elseif roll <= 12 then
					isBehemoth = true
					hpMultiplier = 8 
					mutationTag = "🧱 "
				elseif roll <= 24 then
					isTitan = true
					hpMultiplier = 3 
					mutationTag = "💪 "
				elseif roll <= 36 then
					speedMultiplier = 4.0 
					mutationTag = "🚀 "
				elseif roll <= 55 then
					speedMultiplier = 1.95 
					mutationTag = "⚡ "
				end
				
				local finalHp = math.floor(dataStructure.BaseHP * hpMultiplier * dynamicScaling)
				local calculatedTitle = mutationTag .. dataStructure.Name
				
				local frame, lbl = BuildVessel(math.random(15, 85)/100, -0.08 * i, calculatedTitle, finalHp, dataStructure.Color, false, isTitan, isBehemoth)
				table.insert(Enemies, {
					Frame = frame, 
					Label = lbl, 
					HP = finalHp, 
					MaxHP = finalHp, 
					IsBoss = false, 
					SpeedMod = dataStructure.SpeedModifier * speedMultiplier * dynamicScaling, 
					IsRainbow = isRainbow,
					Data = dataStructure,
					DisplayTitle = calculatedTitle
				})
			end
		end
		
		UpdateUI()
		GameState.Spawning = false
	end)
end

local function CheckCollision(gui1, gui2)
	local p1, s1 = gui1.AbsolutePosition, gui1.AbsoluteSize
	local p2, s2 = gui2.AbsolutePosition, gui2.AbsoluteSize
	return p1.X < p2.X + s2.X and p2.X < p1.X + s1.X and p1.Y < p2.Y + s2.Y and p2.Y < p1.Y + s1.Y
end

local function StartGame()
	for _, e in pairs(Enemies) do if e.Frame then e.Frame:Destroy() end end
	for _, b in pairs(Bullets) do if b.Frame then b.Frame:Destroy() end end
	for _, d in pairs(Drops) do if d.Instance then d.Instance:Destroy() end end
	Enemies = {}
	Bullets = {}
	Drops = {}
	
	GameState.Score = 0
	GameState.Wave = 0
	GameState.Health = GameState.MaxHealth
	GameState.Active = true
	GameState.Paused = false
	GameState.Spawning = false
	Overlay.Visible = false
	Jet.Position = UDim2.new(0.5, 0, 0.88, 0)
	
	UpdateUI()
	StartNextWave()
end

local function GameOver()
	GameState.Active = false
	Overlay.Text = "HULL DESTRUCTION OBSERVED\n\nCLICK TO INITIALIZE RE-FLIGHT"
	Overlay.TextColor3 = Color3.fromRGB(250, 50, 50)
	Overlay.Visible = true
end

