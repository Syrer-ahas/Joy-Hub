--------------------------------------------------------------------------------
Connections.MainLoop = RunService.Heartbeat:Connect(function(dt)
	if not GameState.Active or GameState.Paused then return end
	
	if steerDirection ~= 0 then
		local newX = math.clamp(Jet.Position.X.Scale + (steerDirection * GameState.Speed), 0.06, 0.94)
		Jet.Position = UDim2.new(newX, 0, Jet.Position.Y.Scale, 0)
	end
	
	FireWeaponArray()
	
	for i = #Bullets, 1, -1 do
		local b = Bullets[i]
		if b and b.Frame and b.Frame.Parent then
			b.Frame.Position = UDim2.new(b.Frame.Position.X.Scale, 0, b.Frame.Position.Y.Scale - (0.34 * dt), 0)
			if b.Frame.Position.Y.Scale < -0.05 then
				b.Frame:Destroy()
				table.remove(Bullets, i)
			end
		else
			table.remove(Bullets, i)
		end
	end
	
	-- COIN SCALING CALCULUS: Adds an additive +0.5x multiplier every 5 waves
	local coinScaling = 1 + (0.5 * math.floor((GameState.Wave - 1) / 5))
	
	for i = #Drops, 1, -1 do
		local d = Drops[i]
		if d and d.Instance and d.Instance.Parent then
			local jetX = Jet.Position.X.Scale
			local jetY = Jet.Position.Y.Scale
			local distance = math.sqrt(math.pow(d.X - jetX, 2) + math.pow(d.Y - jetY, 2))
			
			if distance <= GameState.MagnetRange then
				d.Homing = true
			end
			
			if d.Homing then
				d.X = d.X + (jetX - d.X) * (GameState.MagnetSpeed * dt * 14)
				d.Y = d.Y + (jetY - d.Y) * (GameState.MagnetSpeed * dt * 14)
			else
				d.Y = d.Y + (0.09 * dt)
			end
			
			d.Instance.Position = UDim2.new(d.X, 0, d.Y, 0)
			
			if distance < 0.05 then
				if d.Type == "Coin" then
					-- Applied dynamic coin scaling to physical map pickups
					GameState.Coins = GameState.Coins + math.floor(math.random(8, 15) * GameState.CoinMultiplier * coinScaling)
				else
					GameState.Health = math.min(GameState.MaxHealth, GameState.Health + 10)
				end
				d.Instance:Destroy()
				table.remove(Drops, i)
				UpdateUI()
			elseif d.Y > 1.05 then
				d.Instance:Destroy()
				table.remove(Drops, i)
			end
		else
			table.remove(Drops, i)
		end
	end
	
	for i = #Enemies, 1, -1 do
		local e = Enemies[i]
		if e and e.Frame and e.Frame.Parent then
			local frame = e.Frame
			
			if e.IsBoss then
				local stepY = frame.Position.Y.Scale + (0.012 * dt)
				local stepX = frame.Position.X.Scale + (e.DirectionX * 0.22 * dt)
				if stepX > 0.76 or stepX < 0.24 then
					e.DirectionX = -e.DirectionX
				end
				frame.Position = UDim2.new(stepX, 0, stepY, 0)
			else
				frame.Position = UDim2.new(frame.Position.X.Scale, 0, frame.Position.Y.Scale + (0.045 * e.SpeedMod * dt), 0)
			end
			
			if e.IsRainbow then
				frame.BackgroundColor3 = Color3.fromHSV((os.clock() * 2.5) % 1, 0.85, 0.95)
			end
			
			for j = #Bullets, 1, -1 do
				local b = Bullets[j]
				if b and b.Frame and CheckCollision(b.Frame, frame) then
					local dealDmg = b.IsCrit and (GameState.Damage * 2) or GameState.Damage
					if e.IsBoss then dealDmg = dealDmg * GameState.BossSlayerMult end
					
					e.HP = e.HP - dealDmg
					e.Label.Text = e.DisplayTitle .. " [" .. math.max(0, e.HP) .. "]"
					
					b.Life = b.Life - 1
					if b.Life <= 0 then
						b.Frame:Destroy()
						table.remove(Bullets, j)
					end
					
					local oldCol = frame.BackgroundColor3
					frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					task.delay(0.04, function() if frame and not e.IsRainbow then frame.BackgroundColor3 = oldCol end end)
				end
			end
			
			if e.HP <= 0 then
				GameState.Score = GameState.Score + math.floor(e.Data.ScoreAward * GameState.ScoreEngine)
				
				if e.IsRainbow then
					-- Applied dynamic coin scaling onto direct rainbow drop payouts
					local rainbowPayout = math.floor(100 * coinScaling)
					GameState.Coins = GameState.Coins + rainbowPayout
					
					local notifyPop = Instance.new("TextLabel")
					notifyPop.Size = UDim2.new(0.8, 0, 0.05, 0)
					notifyPop.Position = UDim2.new(0.1, 0, 0.22, 0)
					notifyPop.BackgroundTransparency = 1
					notifyPop.Text = "🌈 RAINBOW PAYOUT: +" .. rainbowPayout .. " COINS!"
					notifyPop.TextColor3 = Color3.fromRGB(255, 230, 0)
					notifyPop.Font = Enum.Font.GothamBold
					notifyPop.TextSize = 10
					notifyPop.ZIndex = 8
					notifyPop.Parent = Canvas
					TweenService:Create(notifyPop, TweenInfo.new(1.4), {TextTransparency = 1, Position = UDim2.new(0.1, 0, 0.12, 0)}):Play()
					task.delay(1.4, function() notifyPop:Destroy() end)
				end
				
				if e.IsBoss then
					for k = 1, 6 do
						SpawnLootDrop(frame.Position.X.Scale + (math.random(-10, 10)/100), frame.Position.Y.Scale + (math.random(-5, 5)/100), "Coin")
					end
					SpawnLootDrop(frame.Position.X.Scale, frame.Position.Y.Scale, "PowerUp")
				else
					if e.Data.BaseHP >= 30 then
						if math.random(100) <= 10 then
							SpawnLootDrop(frame.Position.X.Scale, frame.Position.Y.Scale, "PowerUp")
						end
						SpawnLootDrop(frame.Position.X.Scale, frame.Position.Y.Scale, "Coin")
					elseif math.random(100) <= 40 then
						SpawnLootDrop(frame.Position.X.Scale, frame.Position.Y.Scale, "Coin")
					end
				end
				
				frame:Destroy()
				table.remove(Enemies, i)
				UpdateUI()
			elseif CheckCollision(frame, Jet) or frame.Position.Y.Scale > 1.02 then
				if not (math.random(100) <= GameState.DodgeChance) then
					local loss = e.IsBoss and 40 or 12
					GameState.Health = math.max(0, GameState.Health - loss)
				end
				
				frame:Destroy()
				table.remove(Enemies, i)
				UpdateUI()
				
				if GameState.Health <= 0 then
					GameOver()
				end
			end
		else
			table.remove(Enemies, i)
		end
	end
	
	if #Enemies == 0 and GameState.Active and not GameState.Spawning then
		StartNextWave()
	end
end)

