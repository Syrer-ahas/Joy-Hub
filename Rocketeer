local function TrackNavigation(input)
	if not GameState.Active or GameState.Paused then return end
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		local relativeX = (input.Position.X - Canvas.AbsolutePosition.X) / Canvas.AbsoluteSize.X
		Jet.Position = UDim2.new(math.clamp(relativeX, 0.06, 0.94), 0, Jet.Position.Y.Scale, 0)
	end
end

