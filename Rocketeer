local function ConnectShopTrigger(key, callback)
	Connections[key .. "Upgrade"] = UpgradeButtons[key].MouseButton1Click:Connect(function()
		local data = GameState.Upgrades[key]
		if GameState.Coins >= data.Cost then
			GameState.Coins = GameState.Coins - data.Cost
			data.Level = data.Level + 1
			callback(data)
			data.Cost = math.floor(data.Cost * 1.55)
			UpdateUI()
		end
	end)
end

