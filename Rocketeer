end

local function AdjustScale(amount)
	local currentCamera = Workspace.CurrentCamera
	local maxAllowedX = currentCamera and (currentCamera.ViewportSize.X * 0.95) or 1200
	local maxAllowedY = currentCamera and (currentCamera.ViewportSize.Y * 0.95) or 800
	
	local targetX = math.clamp(ScaleConfig.CurrentX + amount, ScaleConfig.MinX, maxAllowedX)
	local targetY = math.clamp(ScaleConfig.CurrentY + (amount * 0.76), ScaleConfig.MinY, maxAllowedY)
	
	ScaleConfig.CurrentX = targetX
	ScaleConfig.CurrentY = targetY
	
	MainFrame.Size = UDim2.new(0, targetX, 0, targetY)
end

Connections.ScaleUp = PlusBtn.MouseButton1Click:Connect(function() AdjustScale(ScaleConfig.Step) end)
Connections.ScaleDown = MinusBtn.MouseButton1Click:Connect(function() AdjustScale(-ScaleConfig.Step) end)

local function TriggerTemporalStasis()
	if GameState.Paused or GameState.PauseCooldown or not GameState.Active then return end
	GameState.Paused = true
	GameState.PauseCooldown = true
	StopBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
	
	task.spawn(function()
		for i = 5, 1, -1 do
			StopBtn.Text = "⏳ STASIS: " .. i .. "s"
			task.wait(1)
		end
		GameState.Paused = false
		StopBtn.Text = "⏸ COOLDOWN"
		
		task.wait(8) 
		StopBtn.BackgroundColor3 = Color3.fromRGB(160, 20, 240)
		StopBtn.Text = "⏸ STASIS"
		GameState.PauseCooldown = false
	end)
end

Connections.StasisTrigger = StopBtn.MouseButton1Click:Connect(TriggerTemporalStasis)

