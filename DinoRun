-- Reset Operational Game System Functions Post Collapse
local function resetGameSystem()
    for _, obs in ipairs(activeObstacles) do
        obs:Destroy()
    end
    activeObstacles = {}
    
    currentSpeed = 0.3
    currentScore = 0
    timeElapsed = 0
    isSpeedCapped = false
    speedCapTimer = 0
    speedCapCompleted = false
    dinoYVelocity = 0
    Dino.Position = UDim2.new(0, 50, 0, groundYPos)
    isJumpingState = false
    itemSpawnCountdown = 0.5
    gameActive = true
    NotificationLabel.Text = ""
end

-- Structural Intersection Evaluation Bounding Boxes
local function isColliding(element1, element2)
    local absPos1, absSize1 = element1.AbsolutePosition, element1.AbsoluteSize
    local absPos2, absSize2 = element2.AbsolutePosition, element2.AbsoluteSize
    
    -- Compact offset padding buffers to feel accurate and satisfyingly fair
    return absPos1.X < absPos2.X + absSize2.X - 8 and
           absPos1.X + absSize1.X - 8 > absPos2.X and
           absPos1.Y < absPos2.Y + absSize2.Y - 5 and
           absPos1.Y + absSize1.Y - 5 > absPos2.Y
end

-- Primary Run-Loop Matrix Connect Update Channel
local connection
connection = RunService.Heartbeat:Connect(function(deltaTime)
    if not ScreenGui or not ScreenGui.Parent then
        connection:Disconnect()
        return
    end
    
    -- Animate the Outline Border Gradient Cycle
    BorderGradient.Rotation = (BorderGradient.Rotation + (deltaTime * 110)) % 360
    
    if not gameActive then return end
    
    timeElapsed = timeElapsed + deltaTime
    currentScore = math.floor(timeElapsed * 12)
    
    -- Linear Velocity Progression System Math Scaling
    if not isSpeedCapped then
        currentSpeed = currentSpeed + (0.1 * deltaTime)
        
        -- Cap check engine activation logic at newly defined Speed 15 threshold
        if currentSpeed >= targetCapSpeed and not speedCapCompleted then
            currentSpeed = targetCapSpeed
            isSpeedCapped = true
            speedCapTimer = 60.0
        end
    else
        -- Active Speed Cap Hold Multipliers
        speedCapTimer = speedCapTimer - deltaTime
        NotificationLabel.Text = string.format("⚡ LOCK: %ds ", math.ceil(speedCapTimer))
        if speedCapTimer <= 0 then
            isSpeedCapped = false
            speedCapCompleted = true
            NotificationLabel.Text = "🚀 VELOCITY UNLOCKED!"
            task.delay(2, function() if gameActive then NotificationLabel.Text = "" end end)
        end
    end
    
    MetricsLabel.Text = string.format("Speed: %.2f | Score: %d", currentSpeed, currentScore)
    
    -- Gravity Kinematics Vector Engine Logic
    if isJumpingState then
        dinoYVelocity = dinoYVelocity + (gravityAcceleration * deltaTime)
        local currentYOffset = Dino.Position.Y.Offset + (dinoYVelocity * deltaTime)
        
        if currentYOffset >= groundYPos then
            currentYOffset = groundYPos
            dinoYVelocity = 0
            isJumpingState = false
        end
        Dino.Position = UDim2.new(0, 50, 0, currentYOffset)
    end
    
    -- Fixed & Optimized Obstacle Spawner Ticks
    itemSpawnCountdown = itemSpawnCountdown - deltaTime
    if itemSpawnCountdown <= 0 then
        local obstacleChoice = math.random(1, 2)
        local obstacleItem = Instance.new("TextLabel")
        obstacleItem.BackgroundTransparency = 1
        obstacleItem.Font = Enum.Font.GothamBold
        
        if obstacleChoice == 1 then
            obstacleItem.Text = "🌵"
            obstacleItem.TextSize = 24
            obstacleItem.Size = UDim2.new(0, 24, 0, 26)
            obstacleItem.Position = UDim2.new(1, 0, 0, 184) -- Perfectly placed over the line
        else
            obstacleItem.Text = "🌴"
            obstacleItem.TextSize = 26
            obstacleItem.Size = UDim2.new(0, 26, 0, 30)
            obstacleItem.Position = UDim2.new(1, 0, 0, 180)
        end
        
        obstacleItem.Parent = GameArea
        table.insert(activeObstacles, obstacleItem)
        
        -- Fast responsive spawns balancing algorithm: ranges from ~1.2 to 2.8 seconds apart early on
        itemSpawnCountdown = math.random(14, 28) / (math.clamp(currentSpeed, 0.3, 8) + 4.5)
    end
    
    -- Translate Obstacles Right-to-Left and Verify Collisions
    for index = #activeObstacles, 1, -1 do
        local currentObstacle = activeObstacles[index]
        if currentObstacle and currentObstacle.Parent then
            -- Frame Translation Scaling Constants
            local translationPixels = (currentSpeed * 45) + 160
            currentObstacle.Position = currentObstacle.Position - UDim2.new(0, translationPixels * deltaTime, 0, 0)
            
            -- Call Collision Verification Sweeper Matrices
            if isColliding(Dino, currentObstacle) then
                gameActive = false
                NotificationLabel.Text = "💥 DEFEATED! Tap to restart..."
                task.wait(0.8)
                
                -- Yield for active user input context tap to clear game cycle
                local clickToRestartConnection
                clickToRestartConnection = MobileClickZone.MouseButton1Click:Connect(function()
                    clickToRestartConnection:Disconnect()
                    resetGameSystem()
                end)
                return
            end
            
            -- Garbage Collector for Off-screen Assets
            if currentObstacle.AbsolutePosition.X < GameArea.AbsolutePosition.X - 40 then
                currentObstacle:Destroy()
                table.remove(activeObstacles, index)
            end
        end
    end
end)
