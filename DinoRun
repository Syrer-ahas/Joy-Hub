-- Core State Variables Engine
local gameActive = true
local currentSpeed = 0.3
local currentScore = 0
local timeElapsed = 0

-- Updated Speed 15 Cap Constraints
local targetCapSpeed = 15.0
local isSpeedCapped = false
local speedCapTimer = 0
local speedCapCompleted = false

-- Engine Physics Constant Adjustments
local groundYPos = 176
local dinoYVelocity = 0
local gravityAcceleration = 1650 -- Crisp snappy physics fall weight
local initialJumpVelocity = -460
local isJumpingState = false

local activeObstacles = {}
local itemSpawnCountdown = 0.8 -- First element drops almost immediately!

-- Trigger Jumping Action Vector Calculations
local function triggerDinoJump()
    if not isJumpingState and gameActive then
        isJumpingState = true
        dinoYVelocity = initialJumpVelocity
    end
end

-- Map Mechanical Control Triggers
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.Space then
        triggerDinoJump()
    end
end)

