--------------------------------------------------------------------------------
-- 🔄 SMOOTH DRAG INTEGRATION MACHINE (MANUAL DELTA CALCULATIONS)
--------------------------------------------------------------------------------

local dragToggle = false
local dragStart = nil
local startPos = nil

local function updateDragInput(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

local function initiateDragSequence(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragToggle = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragToggle = false
            end
        end)
    end
end

MainFrame.InputBegan:Connect(initiateDragSequence)
MinimizeBtn.InputBegan:Connect(initiateDragSequence) -- Allows drag handling from minimized dot button frame directly

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggle then
        updateDragInput(input)
    end
end)

local dragToggleFPS = false
local dragStartFPS = nil
local startPosFPS = nil

FpsLabel.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragToggleFPS = true
        dragStartFPS = input.Position
        startPosFPS = FpsLabel.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragToggleFPS = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragToggleFPS then
        local delta = input.Position - dragStartFPS
        FpsLabel.Position = UDim2.new(startPosFPS.X.Scale, startPosFPS.X.Offset + delta.X, startPosFPS.Y.Scale, startPosFPS.Y.Offset + delta.Y)
    end
end)

--------------------------------------------------------------------------------
-- ⚙️ BACK-END OPTIMIZATION CORE ENGINE
--------------------------------------------------------------------------------

local activeBoostMode = "None" 
local assetStateCache = {}
local listenerConnection = nil

local function backupAndModifyProperty(instance, property, optimizationValue)
    if not assetStateCache[instance] then
        assetStateCache[instance] = {}
    end
    if assetStateCache[instance][property] == nil then
        local success, originalValue = pcall(function() return instance[property] end)
        if success then
            assetStateCache[instance][property] = originalValue
        else
            assetStateCache[instance][property] = nil
        end
    end
    pcall(function() instance[property] = optimizationValue end)
end

local function applyTargetOptimizations(object)
    if activeBoostMode == "None" then return end
    
    -- Absolute ImageId Decal & Texture Purging Channel
    if object:IsA("Decal") or object:IsA("Texture") then
        if activeBoostMode == "Medium" or activeBoostMode == "Extreme" then
            backupAndModifyProperty(object, "Texture", "")
        end
    end
    
    -- Optimize Mesh & Block Materials + Turn Off Shadows
    if object:IsA("BasePart") or object:IsA("MeshPart") then
        if activeBoostMode == "Medium" or activeBoostMode == "Extreme" then
            backupAndModifyProperty(object, "Material", Enum.Material.SmoothPlastic)
        end
        if activeBoostMode == "Extreme" then
            backupAndModifyProperty(object, "CastShadow", false)
        end
    end
    
    -- Optimize Physical Rendering Light Sources (Eliminates Light Rendering Overheads)
    if object:IsA("Light") then -- Catches PointLight, SpotLight, SurfaceLight
        if activeBoostMode == "Medium" or activeBoostMode == "Extreme" then
            backupAndModifyProperty(object, "Enabled", false)
        end
    end
    
    -- Strip Severe Performance Bloat (Particles, Apparel Rendering, Skybox Shaders, UGC Items)
    if activeBoostMode == "Extreme" then
        if object:IsA("ParticleEmitter") or object:IsA("Trail") or object:IsA("Beam") or object:IsA("Fire") or object:IsA("Smoke") then
            backupAndModifyProperty(object, "Enabled", false)
        end
        -- Remove Player Clothing Assets
        if object:IsA("Shirt") or object:IsA("Pants") or object:IsA("GraphicShirt") or object:IsA("ShirtGraphic") or object:IsA("CharacterMesh") then
            backupAndModifyProperty(object, "Parent", nil) 
        end
        -- Clear UGC Accessories / Hats completely
        if object:IsA("Accessory") or object:IsA("Hat") then
            backupAndModifyProperty(object, "Parent", nil)
        end
    end
end

local function processWorldPurgePipeline(targetMode)
    activeBoostMode = targetMode
    
    -- Apply Engine Adjustments inside Lighting Layer Profiles
    if targetMode == "Medium" or targetMode == "Extreme" then
        backupAndModifyProperty(Lighting, "GlobalShadows", false)
    end
    
    if targetMode == "Extreme" then
        backupAndModifyProperty(Lighting, "EnvironmentSpecularScale", 0)
        backupAndModifyProperty(Lighting, "EnvironmentDiffuseScale", 0)
        for _, postEffect in ipairs(Lighting:GetChildren()) do
            if postEffect:IsA("PostEffect") or postEffect:IsA("Atmosphere") or postEffect:IsA("Clouds") or postEffect:IsA("Sky") then
                backupAndModifyProperty(postEffect, "Enabled", false)
                -- Wipe out Skybox Image Asset links specifically
                if postEffect:IsA("Sky") then
                    backupAndModifyProperty(postEffect, "SkyboxBk", "")
                    backupAndModifyProperty(postEffect, "SkyboxDn", "")
                    backupAndModifyProperty(postEffect, "SkyboxFt", "")
                    backupAndModifyProperty(postEffect, "SkyboxLf", "")
                    backupAndModifyProperty(postEffect, "SkyboxRt", "")
                    backupAndModifyProperty(postEffect, "SkyboxUp", "")
                end
            end
        end
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    end
    
    -- Execute Linear Sweep Over Current Game Workspace Assets
    for _, descendant in ipairs(workspace:GetDescendants()) do
        applyTargetOptimizations(descendant)
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character then
            for _, item in ipairs(player.Character:GetDescendants()) do
                applyTargetOptimizations(item)
            end
        end
    end
    
    -- Open dynamic background indexing capture channels
    if not listenerConnection then
        listenerConnection = workspace.DescendantAdded:Connect(function(newDescendant)
            task.next(function()
                applyTargetOptimizations(newDescendant)
            end)
        end)
    end
end

local function safelyRestoreOriginalStates()
    if listenerConnection then
        listenerConnection:Disconnect()
        listenerConnection = nil
    end
    
    activeBoostMode = "None"
    
    -- Revert objects back to cached states
    for object, properties in pairs(assetStateCache) do
        if object then
            for propertyName, originalValue in pairs(properties) do
                pcall(function()
                    object[propertyName] = originalValue
                end)
            end
        end
    end
    
    assetStateCache = {}
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
end

