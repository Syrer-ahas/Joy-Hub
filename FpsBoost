--------------------------------------------------------------------------------
-- ⏱️ RUNTIME PERFORMANCE UPDATER & GRADIENT TICK CHANNELS
--------------------------------------------------------------------------------

local frameCountAccumulator = 0
local timeDurationAccumulator = 0

local runLoopConnection
runLoopConnection = RunService.Heartbeat:Connect(function(deltaTime)
    if not ScreenGui or not ScreenGui.Parent or not FpsGui or not FpsGui.Parent then
        if listenerConnection then listenerConnection:Disconnect() end
        runLoopConnection:Disconnect()
        return
    end
    
    -- Animate Core Outer High-Vis Neon Borders
    BorderGradient.Rotation = (BorderGradient.Rotation + (deltaTime * 100)) % 360
    
    -- Performance Metrics Logic Tracker Profiles
    frameCountAccumulator = frameCountAccumulator + 1
    timeDurationAccumulator = timeDurationAccumulator + deltaTime
    
    -- Update telemetry exactly every 0.25 Second Interval Step
    if timeDurationAccumulator >= 0.25 then
        local calculatedFpsDecimal = frameCountAccumulator / timeDurationAccumulator
        FpsLabel.Text = string.format("%.2f FPS", calculatedFpsDecimal)
        
        frameCountAccumulator = 0
        timeDurationAccumulator = 0
    end
end)
