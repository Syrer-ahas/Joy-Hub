-- Game Mechanics Matrix
local gameRunning = false
local currentScore = 0
local comboStreak = 0
local roundTimeRemaining = 45.0
local activeTargets = {}
local targetSpawnInterval = 0.72
local currentSpawnTimer = 0

-- Combo Breaker Penalty Logic Mapping
GameArea.InputBegan:Connect(function(input)
    if not gameRunning then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local hitTarget = false
        for _, target in ipairs(activeTargets) do
            if target and target.Parent then
                local pX, pY = target.AbsolutePosition.X, target.AbsolutePosition.Y
                local sX, sY = target.AbsoluteSize.X, target.AbsoluteSize.Y
                local mX, mY = input.Position.X, input.Position.Y
                if mX >= pX and mX <= pX + sX and mY >= pY and mY <= pY + sY then
                    hitTarget = true
                    break
                end
            end
        end
        if not hitTarget then
            comboStreak = 0
            ScoreLabel.Text = string.format("SCORE: %d  |  STREAK: %dx", currentScore, comboStreak)
        end
    end
end)

local function buildHolographicTarget()
    if not gameRunning then return end

    local targetSize = math.random(36, 50) 
    local padding = 20
    local maxX = GameArea.AbsoluteSize.X - targetSize - padding
    local maxY = GameArea.AbsoluteSize.Y - targetSize - padding
    if maxX <= padding then maxX = 450 end
    if maxY <= 60 then maxY = 220 end

    local randomX = math.random(padding, maxX)
    local randomY = math.random(50, maxY)

    -- Base Core Object Button profile
    local TargetObj = Instance.new("TextButton")
    TargetObj.Name = "ActiveTarget"
    TargetObj.Size = UDim2.new(0, 0, 0, 0) 
    TargetObj.Position = UDim2.new(0, randomX + (targetSize/2), 0, randomY + (targetSize/2))
    TargetObj.Text = ""
    TargetObj.ZIndex = 3
    TargetObj.Parent = GameArea

    local TargetCorner = Instance.new("UICorner")
    TargetCorner.CornerRadius = UDim.new(1, 0) -- Perfect Circle profile
    TargetCorner.Parent = TargetObj

    local NeonStroke = Instance.new("UIStroke")
    NeonStroke.Thickness = 3.5
    NeonStroke.Parent = TargetObj

    local CenterDot = Instance.new("Frame")
    CenterDot.Size = UDim2.new(0.32, 0, 0.32, 0)
    CenterDot.Position = UDim2.new(0.34, 0, 0.34, 0)
    CenterDot.ZIndex = 4
    CenterDot.Parent = TargetObj
    Instance.new("UICorner").Parent = CenterDot

    -- SPEED MATRIX MATRIX GENERATOR (Medium -> Extreme Fast)
    local velocityRoll = math.random(1, 100)
    local lifespan = 1.5
    local scoreBonusMultiplier = 1

    if velocityRoll <= 20 then
        -- 🔥 EXTREMELY FAST (Neon Magenta Danger Profile)
        lifespan = math.random(38, 58) / 100 -- 0.38s - 0.58s lifespans
        TargetObj.BackgroundColor3 = Color3.fromRGB(80, 10, 40)
        TargetObj.BackgroundTransparency = 0.25
        NeonStroke.Color = Color3.fromRGB(255, 0, 110) -- High warning pink-red outline
        CenterDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255) -- White-hot core
        scoreBonusMultiplier = 3 -- Triple score reward
    elseif velocityRoll <= 55 then
        -- ⚡ FAST (Orange Threat Profile)
        lifespan = math.random(80, 115) / 100 -- 0.80s - 1.15s lifespans
        TargetObj.BackgroundColor3 = Color3.fromRGB(90, 50, 10)
        TargetObj.BackgroundTransparency = 0.3
        NeonStroke.Color = Color3.fromRGB(255, 160, 0) -- Lightning orange outline
        CenterDot.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        scoreBonusMultiplier = 1.5
    else
        -- 🟢 MEDIUM (Standard Cyber Cyan Profile)
        lifespan = math.random(140, 180) / 100 -- 1.40s - 1.80s lifespans
        TargetObj.BackgroundColor3 = Color3.fromRGB(10, 60, 90)
        TargetObj.BackgroundTransparency = 0.4
        NeonStroke.Color = Color3.fromRGB(0, 240, 255) -- Safe electric cyan outline
        CenterDot.BackgroundColor3 = Color3.fromRGB(0, 255, 150)
        scoreBonusMultiplier = 1
    end

    table.insert(activeTargets, TargetObj)

    -- Pop Scale-In Intro Tweens
    TweenService:Create(TargetObj, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, targetSize, 0, targetSize),
        Position = UDim2.new(0, randomX, 0, randomY)
    }):Play()

    local targetDestroyed = false

    -- Trigger Click Verification Channels
    TargetObj.Activated:Connect(function()
        if targetDestroyed then return end
        targetDestroyed = true

        comboStreak = comboStreak + 1
        local standardBaseValue = 10 * scoreBonusMultiplier
        currentScore = currentScore + math.floor(standardBaseValue * math.clamp(comboStreak, 1, 5))
        ScoreLabel.Text = string.format("SCORE: %d  |  STREAK: %dx", currentScore, comboStreak)

        -- Instant shatter effect feedback
        TweenService:Create(TargetObj, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, targetSize * 1.45, 0, targetSize * 1.45),
            Position = UDim2.new(0, randomX - (targetSize * 0.225), 0, randomY - (targetSize * 0.225)),
            BackgroundTransparency = 1
        }):Play()
        TweenService:Create(NeonStroke, TweenInfo.new(0.12), {Transparency = 1}):Play()
        TweenService:Create(CenterDot, TweenInfo.new(0.12), {BackgroundTransparency = 1}):Play()

        task.delay(0.13, function()
            TargetObj:Destroy()
            local index = table.find(activeTargets, TargetObj)
            if index then table.remove(activeTargets, index) end
        end)
    end)

    -- Expired Target Failure Clock
    task.delay(lifespan, function()
        if TargetObj and TargetObj.Parent and not targetDestroyed then
            targetDestroyed = true
            comboStreak = 0 
            ScoreLabel.Text = string.format("SCORE: %d  |  STREAK: %dx", currentScore, comboStreak)

            local shrinkTween = TweenService:Create(TargetObj, TweenInfo.new(0.15), {
                Size = UDim2.new(0, 0, 0, 0),
                Position = UDim2.new(0, randomX + (targetSize/2), 0, randomY + (targetSize/2))
            })
            shrinkTween:Play()
            shrinkTween.Completed:Connect(function()
                TargetObj:Destroy()
                local index = table.find(activeTargets, TargetObj)
                if index then table.remove(activeTargets, index) end
            end)
        end
    end)
end

local function concludeMatchSession()
    gameRunning = false
    MenuHub.Visible = true
    StartBtn.Text = "RELOAD SYSTEM"
    
    for _, target in ipairs(activeTargets) do
        if target and target.Parent then target:Destroy() end
    end
    activeTargets = {}
    
    TimerLabel.Text = "ROUND FINISHED!"
    ScoreLabel.Text = string.format("FINAL SCORE: %d", currentScore)
end

local function executeStartPipeline()
    currentScore = 0
    comboStreak = 0
    roundTimeRemaining = 45.0
    currentSpawnTimer = 0
    
    ScoreLabel.Text = "SCORE: 0  |  STREAK: 0x"
    TimerLabel.Text = "TIME LEFT: 45.0s"
    
    MenuHub.Visible = false
    gameRunning = true
end

StartBtn.MouseButton1Click:Connect(executeStartPipeline)

-- Core Heartbeat Frame Engine Connect Channel
local runLoopConnection
runLoopConnection = RunService.Heartbeat:Connect(function(deltaTime)
    if not ScreenGui or not ScreenGui.Parent then
        runLoopConnection:Disconnect()
        return
    end
    
    -- DYNAMIC ANIMATED BORDER TIMELINE WAVE SHIFTER
    local runtimeClock = tick()
    BorderGradient.Rotation = (BorderGradient.Rotation + (deltaTime * 110)) % 360
    
    local waveColorCycle = math.sin(runtimeClock * 3.5) * 0.5 + 0.5
    BorderGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 160, 255):Lerp(Color3.fromRGB(0, 255, 215), waveColorCycle)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 80, 240)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 255, 215):Lerp(Color3.fromRGB(0, 160, 255), waveColorCycle))
    })
    
    if not gameRunning then return end
    
    -- Tickdown Match time vectors
    roundTimeRemaining = roundTimeRemaining - deltaTime
    if roundTimeRemaining <= 0 then
        concludeMatchSession()
        return
    else
        TimerLabel.Text = string.format("TIME LEFT: %.1fs", roundTimeRemaining)
    end
    
    -- Automatic scaling spawn triggers
    currentSpawnTimer = currentSpawnTimer + deltaTime
    local adaptiveInterval = math.clamp(targetSpawnInterval - (currentScore * 0.0055), 0.25, targetSpawnInterval)
    
    if currentSpawnTimer >= adaptiveInterval then
        currentSpawnTimer = 0
        buildHolographicTarget()
    end
end)
