    if input.KeyCode == Enum.KeyCode.A or input.KeyCode == Enum.KeyCode.Left then
        moveLeftActive = false
    elseif input.KeyCode == Enum.KeyCode.D or input.KeyCode == Enum.KeyCode.Right then
        moveRightActive = false
    end
end)

local function generateSkyElement(isInitialLayout, optionalY)
    local element = Instance.new("TextLabel")
    element.BackgroundTransparency = 1
    element.Text = inSpace and "✨" or "☁️"
    element.TextSize = inSpace and math.random(14, 24) or math.random(35, 55)
    element.TextTransparency = inSpace and 0.2 or 0.5
    element.Size = UDim2.new(0, 40, 0, 30)
    element.Position = UDim2.new(math.random(5, 95)/100, 0, isInitialLayout and optionalY or -0.15, 0)
    element.ZIndex = 1
    element.Parent = GameArea
    table.insert(activeClouds, element)
end

for i = 1, 4 do generateSkyElement(true, (i - 1) * 0.25) end

local function evaluateCollision(box1, box2)
    local p1, s1 = box1.AbsolutePosition, box1.AbsoluteSize
    local p2, s2 = box2.AbsolutePosition, box2.AbsoluteSize
    return p1.X + 4 < p2.X + s2.X - 4 and
           p1.X + s1.X - 4 > p2.X + 4 and
           p1.Y + 4 < p2.Y + s2.Y - 4 and
           p1.Y + s1.Y - 4 > p2.Y + 4
end

local function runGameResetPipeline()
    for _, item in ipairs(activeHazards) do item:Destroy() end
    activeHazards = {}
    
    currentScore = 0
    timeElapsed = 0
    inSpace = false
    currentActivePlanet = nil
    shieldActive = false
    shieldTimeLeft = 0
    shieldPickupCooldown = 0
    
    ShieldBubble.Size = UDim2.new(1.6, 0, 1.6, 0)
    ShieldBubble.Position = UDim2.new(-0.3, 0, -0.3, 0)
    ShieldBubble.BackgroundTransparency = 1
    ShieldStroke.Transparency = 1
    GameArea.BackgroundColor3 = Color3.fromRGB(110, 195, 245)
    GameArea.Position = UDim2.new(0, 10, 0, 52)
    CelestialObject.Position = UDim2.new(0.5, -50, -0.4, 0)
    CelestialObject.Text = ""
    
    Balloon.Text = "🎈"
    Balloon.Position = UDim2.new(0.85, -16, 0.8, 0) 
    itemSpawnCountdown = 0.6
    AlertLabel.Text = ""
    moveLeftActive = false
    moveRightActive = false
    gameActive = true
end

local function handleTerminalCrash()
    gameActive = false
    GameArea.Position = UDim2.new(0, 10, 0, 52)
    AlertLabel.Text = "💥 POPPED! Tap Sky to Restart..."
    task.wait(0.4)
    
    local rebootTrigger
    rebootTrigger = GameArea.InputBegan:Connect(function(clickInput)
        if clickInput.UserInputType == Enum.UserInputType.MouseButton1 or clickInput.UserInputType == Enum.UserInputType.Touch then
            rebootTrigger:Disconnect()
            runGameResetPipeline()
        end
    end)
end

-- Primary RunLoop Connect Channel
local runLoopConnection
runLoopConnection = RunService.Heartbeat:Connect(function(deltaTime)
    if not ScreenGui or not ScreenGui.Parent then
        runLoopConnection:Disconnect()
        return
    end
    
    BorderGradient.Rotation = (BorderGradient.Rotation + (deltaTime * 100)) % 360
    
    if not gameActive then return end
    
    -- PROGRESSIVE SPEED INTERVAL SCALE: +0.009x per second
    timeElapsed = timeElapsed + deltaTime
    local speedMultiplier = 1.0 + (timeElapsed * 0.009)
    
    currentScore = currentScore + (deltaTime * 32 * speedMultiplier)
    local distance = math.floor(currentScore)
    ScoreLabel.Text = string.format("Distance: %dm (%.3fx Speed)", distance, speedMultiplier)
    
    -- Tick Internal Shield Collection Cooldown Buffers
    if shieldPickupCooldown > 0 then
        shieldPickupCooldown = shieldPickupCooldown - deltaTime
    end
    
    -- Dynamic Shield Engine
    if shieldActive then
        shieldTimeLeft = shieldTimeLeft - deltaTime
        
        if shieldPickupCooldown > 0 then
            AlertLabel.Text = string.format("🛡️ CAP: %.1fs (🔒 COOLDOWN)", shieldTimeLeft)
        else
            AlertLabel.Text = string.format("🛡️ SHIELD STACK: %.1fs", shieldTimeLeft)
        end
        
        -- Shrink/Grow shield visual ring profile dynamically based on stack depth remaining
        local dynamicSizeScale = 1.6 + math.min(shieldTimeLeft * 0.08, 1.4)
        local halfScaleAdjustment = (dynamicSizeScale - 1) / 2
        ShieldBubble.Size = UDim2.new(dynamicSizeScale, 0, dynamicSizeScale, 0)
        ShieldBubble.Position = UDim2.new(-halfScaleAdjustment, 0, -halfScaleAdjustment, 0)
        
        if shieldTimeLeft <= 0 then
            shieldActive = false
            AlertLabel.Text = ""
            TweenService:Create(ShieldBubble, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
            TweenService:Create(ShieldStroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
        end
    end
    
    -- INTENSE PRE-END SOLAR SCREEN SHAKE ENGINE
    -- Begins at 7,500 meters and scales violently up to 12px offsets at the Sun's core
    if distance >= 7500 and distance < 10000 then
        local normalizationFactor = (distance - 7500) / 2500
        local intenseShakeForce = normalizationFactor * 13 -- Up to 13-pixel visual frame displacements
        GameArea.Position = UDim2.new(0, 10 + math.random(-intenseShakeForce, intenseShakeForce), 0, 52 + math.random(-intenseShakeForce, intenseShakeForce))
    elseif speedMultiplier > 1.6 and distance < 7500 then
        -- Standard velocity-induced vibrations
        local minorShake = math.min((speedMultiplier - 1.6) * 1.5, 2.5)
        GameArea.Position = UDim2.new(0, 10 + math.random(-minorShake, minorShake), 0, 52 + math.random(-minorShake, minorShake))
    else
        GameArea.Position = UDim2.new(0, 10, 0, 52)
    end
    
    -- Space Milestones Timeline Channels
    if distance >= 10000 then
        gameActive = false
        Balloon.Text = "💥"
        CelestialObject.Text = "☀️"
        CelestialObject.Position = UDim2.new(0.5, -50, 0.3, 0)
        GameArea.Position = UDim2.new(0, 10, 0, 52)
        AlertLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        AlertLabel.Text = "🎉 VICTORY! YOU REACHED THE SUN!"
        return
    elseif distance >= 5000 then
        if currentActivePlanet ~= "Venus" then
            currentActivePlanet = "Venus"
            CelestialObject.Text = "🟠"
            CelestialObject.Position = UDim2.new(0.5, -50, -0.4, 0)
            TweenService:Create(CelestialObject, TweenInfo.new(4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, -50, 0.15, 0)}):Play()
        end
    elseif distance >= 3000 then
        if currentActivePlanet ~= "Mars" then
            currentActivePlanet = "Mars"
            CelestialObject.Text = "🔴"
            CelestialObject.Position = UDim2.new(0.5, -50, -0.4, 0)
            TweenService:Create(CelestialObject, TweenInfo.new(4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, -50, 0.15, 0)}):Play()
        end
    elseif distance >= 2000 then
        if currentActivePlanet ~= "Moon" then
            currentActivePlanet = "Moon"
            CelestialObject.Text = "🌕"
            CelestialObject.Position = UDim2.new(0.5, -50, -0.4, 0)
            TweenService:Create(CelestialObject, TweenInfo.new(4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, -50, 0.15, 0)}):Play()
        end
    elseif distance >= 1000 then
        if not inSpace then
            inSpace = true
            TweenService:Create(GameArea, TweenInfo.new(3), {BackgroundColor3 = Color3.fromRGB(12, 12, 24)}):Play()
        end
        if distance >= 2800 and currentActivePlanet == "Moon" then
            CelestialObject.Position = CelestialObject.Position + UDim2.new(0, 0, 0, 40 * deltaTime)
        elseif distance >= 4800 and currentActivePlanet == "Mars" then
            CelestialObject.Position = CelestialObject.Position + UDim2.new(0, 0, 0, 40 * deltaTime)
        elseif distance >= 9500 and currentActivePlanet == "Venus" then
            CelestialObject.Position = CelestialObject.Position + UDim2.new(0, 0, 0, 40 * deltaTime)
        end
    end
    
    -- Processing Vector Horizontal Steering
    local horizontalMovementOffset = 0
    if moveLeftActive then
        horizontalMovementOffset = -baseSteeringSpeed * speedMultiplier * deltaTime
    elseif moveRightActive then
        horizontalMovementOffset = baseSteeringSpeed * speedMultiplier * deltaTime
    end
    
    if horizontalMovementOffset ~= 0 then
        local targetXOffset = Balloon.Position.X.Offset + horizontalMovementOffset
        local maxWidthLimit = GameArea.AbsoluteSize.X - Balloon.AbsoluteSize.X
        targetXOffset = math.clamp(targetXOffset, 0, maxWidthLimit)
        Balloon.Position = UDim2.new(0, targetXOffset, Balloon.Position.Y.Scale, Balloon.Position.Y.Offset)
    end
    
    -- Background Environment Engine Parallax Update
    local currentScrollSpeed = (inSpace and 45 or 75) * speedMultiplier
    for idx = #activeClouds, 1, -1 do
        local element = activeClouds[idx]
        if element and element.Parent then
            element.Position = element.Position + UDim2.new(0, 0, 0, currentScrollSpeed * deltaTime)
            if element.AbsolutePosition.Y > GameArea.AbsolutePosition.Y + GameArea.AbsoluteSize.Y then
                element:Destroy()
                table.remove(activeClouds, idx)
                generateSkyElement(false)
            end
        end
    end
    
    -- Threat Deployment System
    itemSpawnCountdown = itemSpawnCountdown - deltaTime
    if itemSpawnCountdown <= 0 then
        local spawnedItem = Instance.new("TextLabel")
        spawnedItem.TextSize = 22
        spawnedItem.Size = UDim2.new(0, 36, 0, 36) 
        spawnedItem.TextXAlignment = Enum.TextXAlignment.Center
        spawnedItem.TextYAlignment = Enum.TextYAlignment.Center
        
        local itemCorner = Instance.new("UICorner")
        itemCorner.CornerRadius = UDim.new(1, 0)
        itemCorner.Parent = spawnedItem
        
        local itemStroke = Instance.new("UIStroke")
        itemStroke.Thickness = 3.2
        itemStroke.Parent = spawnedItem
        
        local itemRoll = math.random()
        if itemRoll <= 0.15 then
            -- 🛡️ Shield Power-Up (Cyan Disk Aura)
            spawnedItem.Name = "ShieldPowerUp"
            spawnedItem.Text = "🛡️"
            spawnedItem.BackgroundColor3 = Color3.fromRGB(0, 90, 220)
            spawnedItem.BackgroundTransparency = 0.65
            itemStroke.Color = Color3.fromRGB(0, 255, 255) 
        else
            -- 🛑 Obstacles (Neon Red Threat Indicators)
            spawnedItem.Name = "Obstacle"
            spawnedItem.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
            spawnedItem.BackgroundTransparency = 0.55 
            itemStroke.Color = Color3.fromRGB(255, 0, 0) 
            
            local spaceObstacles = {"☄️", "⚡", "💣", "🛸", "🔥"}
            local skyObstacles = {"🦅", "⚡", "⛈️", "💣", "🔥"}
            spawnedItem.Text = inSpace and spaceObstacles[math.random(1, #spaceObstacles)] or skyObstacles[math.random(1, #skyObstacles)]
        end
        
        local canvasWidth = GameArea.AbsoluteSize.X
        if canvasWidth == 0 then canvasWidth = 530 end
        spawnedItem.Position = UDim2.new(0, math.random(10, canvasWidth - 46), 0, -40)
        spawnedItem.ZIndex = 3
        spawnedItem.Parent = GameArea
        
        table.insert(activeHazards, spawnedItem)
        itemSpawnCountdown = math.clamp(0.58 / speedMultiplier, 0.18, 0.58)
    end
    
    -- Processing Falling Physics & Matrix Hits
    local fallingSpeed = 190 * speedMultiplier
    for idx = #activeHazards, 1, -1 do
        local currentItem = activeHazards[idx]
        if currentItem and currentItem.Parent then
            currentItem.Position = currentItem.Position + UDim2.new(0, 0, 0, fallingSpeed * deltaTime)
            
            if evaluateCollision(Balloon, currentItem) then
                if currentItem.Name == "ShieldPowerUp" then
                    -- Process shield pickup if off collection cooldown
                    if shieldPickupCooldown <= 0 then
                        shieldActive = true
                        -- STACK CAP: Increase duration by +5s, strict math clamp ceiling at 12 seconds
                        shieldTimeLeft = math.min(shieldTimeLeft + 5.0, 12.0)
                        shieldPickupCooldown = 2.0 -- Trigger 2-second collection cooldown lock
                        
                        TweenService:Create(ShieldBubble, TweenInfo.new(0.2), {BackgroundTransparency = 0.4}):Play()
                        TweenService:Create(ShieldStroke, TweenInfo.new(0.2), {Transparency = 0}):Play()
                    end
                    currentItem:Destroy()
                    table.remove(activeHazards, idx)
                else
                    if not shieldActive then
                        handleTerminalCrash()
                        return
                    else
                        currentItem:Destroy()
                        table.remove(activeHazards, idx)
                    end
                end
            elseif currentItem.AbsolutePosition.Y > GameArea.AbsolutePosition.Y + GameArea.AbsoluteSize.Y then
                currentItem:Destroy()
                table.remove(activeHazards, idx)
            end
        end
    end
end)
